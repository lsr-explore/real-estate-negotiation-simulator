# ─── Real Estate Negotiation Workshop — Environment Variables ─────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your actual .env to git (it's already in .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ─── OpenAI API Key ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ─── GitHub Token (for M1 GitHub MCP demo only) ─────────────────────────────
# Required for: python m1_mcp/github_agent_client.py
# Get a token: GitHub → Settings → Developer Settings → Personal Access Tokens
GITHUB_TOKEN=ghp_your-github-token-here

# ─── Agent Model ─────────────────────────────────────────────────────────────
# Change to openai/gpt-4o-mini for cheaper runs (default: openai/gpt-4o)
# AGENT_MODEL=openai/gpt-4o
